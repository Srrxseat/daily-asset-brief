# Daily Asset Brief — Environment Variables
# คัดลอกไฟล์นี้เป็น .env และกรอกค่าจริง

# ─── GitHub ───────────────────────────────────────────────────────────────────
# GitHub username หรือ org name ที่เป็นเจ้าของ repo
GITHUB_OWNER=srrxseat

# ชื่อ repo (ต้องตรงกับที่สร้างไว้บน GitHub)
GITHUB_REPO=daily-asset-brief

# ─── LINE Messaging API ───────────────────────────────────────────────────────
# Channel Access Token จาก LINE Developers Console
# https://developers.line.biz/console/
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token

# LINE User ID หรือ Group ID ที่จะส่งข้อความถึง
# User ID: เริ่มด้วย "U"  เช่น Ue8c7d21f...
# Group ID: เริ่มด้วย "C" เช่น C4af4980f...
LINE_TO=your-line-user-or-group-id
